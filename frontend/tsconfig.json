{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,

    "paths": {
      "@/*": ["./src/*"]
    },

    "types": ["vite/client", "node", "jest", "@testing-library/jest-dom"]
  },
  "include": ["src"]
}
